AA,EACpF,EAAE,IAAI,KAAK,WAAW,SAAS,SAAS,SAAS,OAAO,MAAM,OAAO,cAAc,CAAC,EAAA;AAAA,EACpF,EAAE,IAAI,KAAK,WAAW,SAAS,SAAS,SAAS,OAAO,MAAM,OAAO,cAAc,CAAC,EAAA;AACtF;AAEA,MAAM,gBAAgB,CAAC,SAAyB;AAC9C,QAAM,CAAC,OAAO,OAAO,IAAI,KAAK,MAAM,GAAG,EAAE,IAAI,MAAM;AACnD,SAAO,QAAQ,KAAK;AACtB;AA2BA,MAAM,kBAAkB,CAAC,UAAkC;AACzD,SAAO,CAAC,GAAG,KAAK,EAAE;AAAA,IAAK,CAAC,GAAG,MACzB,cAAc,EAAE,SAAS,IAAI,cAAc,EAAE,SAAS;AAAA,EAAA;AAE1D;AAEO,SAAS,eAAe;AAC7B,QAAM,OAAO,IAAmB;AAAA,IAC9B,OAAO;AAAA,IACP,OAAO,gBAAgB,CAAC,GAAG,YAAY,CAAC;AAAA,EAAA,CACzC;AAED,QAAM,YAAY,IAAmB,IAAI;AACzC,QAAM,aAAa,IAAI,KAAK;AAc5B,QAAM,MAAM,CAAC,YAAY;AACvB,QAAI,WAAW,OAAO;AACpB,mBAAa,QAAQ,aAAa,KAAK,UAAU,OAAO,CAAC;AAAA,IAC3D;AAAA,EACF,GAAG,EAAE,MAAM,MAAM;AAEjB,QAAM,UAAU,CAAC,aAAoC;AACnD,UAAM,SAAS,KAAK,IAAA,EAAM,SAAA;AAC1B,UAAM,UAAoB,WAAW;AAAA,MACnC,IAAI;AAAA,MACJ,GAAG;AAAA,IAAA,IACD;AAAA,MACF,IAAI;AAAA,MACJ,WAAW;AAAA,MACX,SAAS;AAAA,MACT,OAAO;AAAA,MACP,OAAO,cAAc,KAAK,MAAM,MAAM,SAAS,cAAc,MAAM;AAAA,IAAA;AAGrE,UAAM,WAAW,CAAC,GAAG,KAAK,MAAM,OAAO,OAAO;AAC9C,SAAK,MAAM,QAAQ,gBAAgB,QAAQ;AAC3C,cAAU,QAAQ;AAClB,WAAO;AAAA,EACT;AAEA,QAAM,aAAa,CAAC,IAAY,YAAwC;AACtE,UAAM,QAAQ,KAAK,MAAM,MAAM,UAAU,CAAA,MAAK,EAAE,OAAO,EAAE;AACzD,QAAI,UAAU,GAAI,QAAO;AAEzB,UAAM,cAAc,KAAK,MAAM,MAAM,KAAK;AAC1C,UAAM,cAAc,EAAE,GAAG,aAAa,GAAG,QAAA;AAEzC,UAAM,YAAY,QAAQ,aAAa,YAAY;AACnD,UAAM,UAAU,QAAQ,WAAW,YAAY;AAE/C,UAAM,WAAW,CAAC,GAAG,KAAK,MAAM,KAAK;AACrC,aAAS,KAAK,IAAI;AAClB,SAAK,MAAM,QAAQ,gBAAgB,QAAQ;AAE3C,QAAI,cAAc,SAAS,KAAK,cAAc,OAAO,GAAG;AACtD,gBAAU,QAAQ;AAAA,IACpB,OAAO;AACL,gBAAU,QAAQ;AAAA,IACpB;AAEA,WAAO;AAAA,EACT;AAEA,QAAM,aAAa,CAAC,OAAe;AACjC,SAAK,MAAM,QAAQ,KAAK,MAAM,MAAM,OAAO,CAAA,MAAK,EAAE,OAAO,EAAE;AAAA,EAC7D;AAEA,QAAM,iBAAiB,MAAM;AAC3B,SAAK,QAAQ;AAAA,MACX,OAAO;AAAA,MACP,OAAO,gBAAgB,CAAC,GAAG,YAAY,CAAC;AAAA,IAAA;AAE1C,cAAU,QAAQ;AAAA,EACpB;AAEA,QAAM,aAAa,MAAM;AACvB,cAAU,QAAQ;AAAA,EACpB;AAEA,SAAO;AAAA,IACL;AAAA,IACA;AAAA,IACA;AAAA,IACA;AAAA,IACA;AAAA,IACA;AAAA,IACA;AAAA,IACA;AAAA,EAAA;AAEJ;;;;;AC1JA,UAAM,EAAE,MAAM,SAAS,YAAY,YAA4B,eAAAK,gBAAe,UAAsB,IAAI,aAAA;AAExG,UAAM,YAAY,IAAwB,MAAM;AAChD,UAAM,aAAa,IAAkD,IAAI;AACzE,UAAM,eAAe,IAAI,KAAK;AAqB9B,UAAM,mBAAmB,CAAC,IAAY,YAA+B;AACnE,iBAAW,IAAI,OAAO;AAAA,IACxB;AAEA,UAAM,mBAAmB,CAAC,OAAe;AACvC,iBAAW,EAAE;AAAA,IACf;AAMA,UAAM,qBAAqB,CAAC,aAAmC;AAC7D,cAAQ,QAAQ;AAChB,mBAAa,QAAQ;AAAA,IACvB;AAEA,UAAM,mBAAmB,MAAM;AAC7B,mBAAa,QAAQ;AAAA,IACvB;;;;;AAIO,YAAA,OAAAR,eAAAC,WAAA,EAAA,OAAM,wEAAoE,MAAA,CAAA,CAAA,maAAA;UAgB7DE,MAAA,SAAA,MAAS,WAAA;;;;;uFAgBTA,MAAA,SAAA,MAAS,SAAA,2BAAA,+CAAA,4DAAA,CAAA,oDAOTA,MAAA,SAAA,MAAS,YAAA,2BAAA,+CAAA,4DAAA,CAAA;UASZA,MAAA,SAAA,MAAS,QAAA;uHAILM,cAAA,SAAAN,MAAA,IAAA,EAAK,KAAK,gVASkBA,MAAA,IAAA,EAAK,MAAM,MAAM;YAIlDA,MAAA,SAAA,GAAS;mXAMZA,MAAA,SAAA,CAAS,CAAA,QAAA;AAAA;;;;sBAKKA,MAAA,IAAA,EAAK,OAAK,CAAlB,SAAI;;YACV,KAAK,KAAK;AAAA,YACV;AAAA,YACA,QAAQA,MAAAK,cAAA;AAAA,YACR,UAAQ;AAAA,YACR,UAAQ;AAAA,UAAA;;;;;;mBAgBS;AAAA,UAAJ,KAAI;AAAA,UAAc,MAAML,MAAA,IAAA;AAAA,QAAA;;;;;QAK3C,MAAMA,MAAA,YAAA;AAAA,QACN,QAAQA,MAAAK,cAAA;AAAA,QACR,SAAO;AAAA,QACP,WAAS;AAAA,MAAA;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderStyle","_unref","_ssrRenderList","_ssrInterpolate","_push","_ssrRenderClass","defaultColors","_ssrRenderAttr"],"sources":["../../../../components/TimeSlotEditor.vue","../../../../components/TimetablePreview.vue","../../../../components/AddSlotModal.vue","../../../../composables/useTimetable.ts","../../../../pages/index.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { TimeSlot } from '~/types'\n\ninterface Props {\n  slot: TimeSlot\n  colors: string[]\n}\n\ninterface Emits {\n  (e: 'update', id: string, updates: Partial<TimeSlot>): void\n  (e: 'delete', id: string): void\n}\n\nconst props = defineProps<Props>()\nconst emit = defineEmits<Emits>()\n\nconst showColorPicker = ref(false)\n\nconst selectColor = (color: string) => {\n  emit('update', props.slot.id, { color })\n  showColorPicker.value = false\n}\n</script>\n\n<template>\n  <div class=\"bg-white rounded-xl shadow-sm p-4 mb-3 border border-gray-100\">\n    <div class=\"flex items-center gap-4\">\n      <div class=\"relative\">\n        <button\n          @click=\"showColorPicker = !showColorPicker\"\n          class=\"w-12 h-12 rounded-lg border-2 border-gray-200 hover:border-gray-400 transition-colors\"\n          :style=\"{ backgroundColor: slot.color }\"\n        />\n        <div\n          v-if=\"showColorPicker\"\n          class=\"absolute top-full left-0 mt-2 p-2 bg-white rounded-lg shadow-lg border z-10 grid grid-cols-4 gap-1\"\n        >\n          <button\n            v-for=\"color in colors\"\n            :key=\"color\"\n            @click=\"selectColor(color)\"\n            class=\"w-8 h-8 rounded border border-gray-200 hover:scale-110 transition-transform\"\n            :style=\"{ backgroundColor: color }\"\n          />\n        </div>\n      </div>\n\n      <div class=\"flex-1 grid grid-cols-12 gap-3\">\n        <div class=\"col-span-5\">\n          <label class=\"text-xs text-gray-500 mb-1 block\">时段</label>\n          <div class=\"flex items-center gap-2\">\n            <input\n              type=\"time\"\n              :value=\"slot.startTime\"\n              @input=\"emit('update', slot.id, { startTime: ($event.target as HTMLInputElement).value })\"\n              class=\"flex-1 px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\n            />\n            <span class=\"text-gray-400\">-</span>\n            <input\n              type=\"time\"\n              :value=\"slot.endTime\"\n              @input=\"emit('update', slot.id, { endTime: ($event.target as HTMLInputElement).value })\"\n              class=\"flex-1 px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\n            />\n          </div>\n        </div>\n\n        <div class=\"col-span-6\">\n          <label class=\"text-xs text-gray-500 mb-1 block\">日程标签</label>\n          <input\n            type=\"text\"\n            :value=\"slot.label\"\n            @input=\"emit('update', slot.id, { label: ($event.target as HTMLInputElement).value })\"\n            placeholder=\"输入日程内容\"\n            class=\"w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\n          />\n        </div>\n      </div>\n\n      <button\n        @click=\"emit('delete', slot.id)\"\n        class=\"p-2 text-red-500 hover:bg-red-50 rounded-lg transition-colors\"\n        title=\"删除时段\"\n      >\n        <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" />\n        </svg>\n      </button>\n    </div>\n  </div>\n</template>\n","<script setup lang=\"ts\">\nimport type { TimetableData } from '~/types'\n\ninterface Props {\n  data: TimetableData\n}\n\nconst props = defineProps<Props>()\nconst timetableRef = ref<HTMLDivElement | null>(null)\n\nconst sortedSlots = computed(() => {\n  return [...props.data.slots].sort((a, b) => \n    a.startTime.localeCompare(b.startTime)\n  )\n})\n\ndefineExpose({\n  timetableRef\n})\n</script>\n\n<template>\n  <div ref=\"timetableRef\" class=\"bg-white rounded-2xl shadow-xl p-8 max-w-2xl mx-auto\">\n    <h1 class=\"text-2xl font-bold text-center mb-6 text-gray-800\">{{ data.title }}</h1>\n    \n    <div class=\"space-y-2\">\n      <div\n        v-for=\"slot in sortedSlots\"\n        :key=\"slot.id\"\n        class=\"flex items-center rounded-lg overflow-hidden shadow-sm\"\n      >\n        <div\n          class=\"w-3 h-full min-h-[60px]\"\n          :style=\"{ backgroundColor: slot.color }\"\n        />\n        <div class=\"flex-1 px-4 py-3 bg-gray-50\">\n          <div class=\"font-semibold text-gray-800\">{{ slot.label }}</div>\n          <div class=\"text-sm text-gray-500\">\n            {{ slot.startTime }} - {{ slot.endTime }}\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"mt-6 text-center text-sm text-gray-400\">\n      生成时间: {{ new Date().toLocaleDateString() }}\n    </div>\n  </div>\n</template>\n","<script setup lang=\"ts\">\nimport type { TimeSlot } from '~/types'\n\ninterface Props {\n  show: boolean\n  colors: string[]\n}\n\ninterface Emits {\n  (e: 'close'): void\n  (e: 'confirm', slot: Omit<TimeSlot, 'id'>): void\n}\n\nconst props = defineProps<Props>()\nconst emit = defineEmits<Emits>()\n\nconst startTime = ref('09:00')\nconst endTime = ref('10:00')\nconst label = ref('新时段')\nconst selectedColor = ref('')\n\nwatch(() => props.show, (newVal) => {\n  if (newVal) {\n    startTime.value = '09:00'\n    endTime.value = '10:00'\n    label.value = '新时段'\n    selectedColor.value = props.colors[0]\n  }\n}, { immediate: true })\n\nconst handleConfirm = () => {\n  emit('confirm', {\n    startTime: startTime.value,\n    endTime: endTime.value,\n    label: label.value,\n    color: selectedColor.value\n  })\n}\n\nconst handleClose = () => {\n  emit('close')\n}\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <Transition name=\"modal\">\n      <div v-if=\"show\" class=\"fixed inset-0 z-50 flex items-center justify-center\">\n        <div class=\"absolute inset-0 bg-black/50\" @click=\"handleClose\" />\n        <div class=\"relative bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 p-6\">\n          <div class=\"flex items-center justify-between mb-6\">\n            <h3 class=\"text-xl font-bold text-gray-800\">添加新时段</h3>\n            <button\n              @click=\"handleClose\"\n              class=\"p-2 hover:bg-gray-100 rounded-lg transition-colors\"\n            >\n              <svg class=\"w-5 h-5 text-gray-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\" />\n              </svg>\n            </button>\n          </div>\n\n          <div class=\"space-y-5\">\n            <div>\n              <label class=\"block text-sm font-medium text-gray-700 mb-2\">时段标签</label>\n              <input\n                v-model=\"label\"\n                type=\"text\"\n                placeholder=\"例如：工作、休息、学习\"\n                class=\"w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all\"\n              />\n            </div>\n\n            <div>\n              <label class=\"block text-sm font-medium text-gray-700 mb-2\">时间</label>\n              <div class=\"flex items-center gap-3\">\n                <input\n                  v-model=\"startTime\"\n                  type=\"time\"\n                  class=\"flex-1 px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all\"\n                />\n                <span class=\"text-gray-400 font-medium\">至</span>\n                <input\n                  v-model=\"endTime\"\n                  type=\"time\"\n                  class=\"flex-1 px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all\"\n                />\n              </div>\n            </div>\n\n            <div>\n              <label class=\"block text-sm font-medium text-gray-700 mb-3\">选择颜色</label>\n              <div class=\"grid grid-cols-8 gap-2\">\n                <button\n                  v-for=\"color in colors\"\n                  :key=\"color\"\n                  @click=\"selectedColor = color\"\n                  class=\"aspect-square rounded-lg border-2 transition-all hover:scale-110\"\n                  :class=\"selectedColor === color ? 'border-blue-500 ring-2 ring-blue-200' : 'border-gray-200'\"\n                  :style=\"{ backgroundColor: color }\"\n                />\n              </div>\n            </div>\n          </div>\n\n          <div class=\"flex gap-3 mt-8\">\n            <button\n              @click=\"handleClose\"\n              class=\"flex-1 px-4 py-3 bg-gray-100 text-gray-700 rounded-xl font-medium hover:bg-gray-200 transition-colors\"\n            >\n              取消\n            </button>\n            <button\n              @click=\"handleConfirm\"\n              class=\"flex-1 px-4 py-3 bg-blue-600 text-white rounded-xl font-medium hover:bg-blue-700 transition-colors\"\n            >\n              确认添加\n            </button>\n          </div>\n        </div>\n      </div>\n    </Transition>\n  </Teleport>\n</template>\n\n<style scoped>\n.modal-enter-active,\n.modal-leave-active {\n  transition: all 0.3s ease;\n}\n\n.modal-enter-from,\n.modal-leave-to {\n  opacity: 0;\n}\n\n.modal-enter-from .relative,\n.modal-leave-to .relative {\n  transform: scale(0.9);\n}\n</style>\n","import type { TimeSlot, TimetableData } from '~/types'\nimport { onMounted, ref, watch } from '#imports'\n\nconst STORAGE_KEY = 'routine-timetable-data'\n\nconst defaultColors = [\n  '#3B82F6',\n  '#10B981',\n  '#F59E0B',\n  '#EF4444',\n  '#8B5CF6',\n  '#EC4899',\n  '#06B6D4',\n  '#84CC16'\n]\n\nconst defaultSlots: TimeSlot[] = [\n  { id: '1', startTime: '06:00', endTime: '07:00', label: '早起运动', color: defaultColors[0] },\n  { id: '2', startTime: '07:00', endTime: '08:00', label: '早餐', color: defaultColors[1] },\n  { id: '3', startTime: '08:00', endTime: '12:00', label: '工作', color: defaultColors[2] },\n  { id: '4', startTime: '12:00', endTime: '13:00', label: '午餐', color: defaultColors[3] },\n  { id: '5', startTime: '13:00', endTime: '18:00', label: '工作', color: defaultColors[2] },\n  { id: '6', startTime: '18:00', endTime: '19:00', label: '晚餐', color: defaultColors[4] },\n  { id: '7', startTime: '19:00', endTime: '21:00', label: '学习', color: defaultColors[5] },\n  { id: '8', startTime: '21:00', endTime: '23:00', label: '休息', color: defaultColors[6] }\n]\n\nconst timeToMinutes = (time: string): number => {\n  const [hours, minutes] = time.split(':').map(Number)\n  return hours * 60 + minutes\n}\n\nconst checkOverlap = (\n  slots: TimeSlot[],\n  excludeId: string | null,\n  startTime: string,\n  endTime: string\n): boolean => {\n  const start = timeToMinutes(startTime)\n  const end = timeToMinutes(endTime)\n\n  if (start >= end) return true\n\n  for (const slot of slots) {\n    if (excludeId && slot.id === excludeId) continue\n\n    const slotStart = timeToMinutes(slot.startTime)\n    const slotEnd = timeToMinutes(slot.endTime)\n\n    if (start < slotEnd && end > slotStart) {\n      return true\n    }\n  }\n\n  return false\n}\n\nconst sortSlotsByTime = (slots: TimeSlot[]): TimeSlot[] => {\n  return [...slots].sort((a, b) => \n    timeToMinutes(a.startTime) - timeToMinutes(b.startTime)\n  )\n}\n\nexport function useTimetable() {\n  const data = ref<TimetableData>({\n    title: '我的作息时间表',\n    slots: sortSlotsByTime([...defaultSlots])\n  })\n\n  const lastError = ref<string | null>(null)\n  const isHydrated = ref(false)\n\n  onMounted(() => {\n    const saved = localStorage.getItem(STORAGE_KEY)\n    if (saved) {\n      const parsed = JSON.parse(saved)\n      data.value = {\n        ...parsed,\n        slots: sortSlotsByTime(parsed.slots)\n      }\n    }\n    isHydrated.value = true\n  })\n\n  watch(data, (newData) => {\n    if (isHydrated.value) {\n      localStorage.setItem(STORAGE_KEY, JSON.stringify(newData))\n    }\n  }, { deep: true })\n\n  const addSlot = (slotData?: Omit<TimeSlot, 'id'>) => {\n    const nextId = Date.now().toString()\n    const newSlot: TimeSlot = slotData ? {\n      id: nextId,\n      ...slotData\n    } : {\n      id: nextId,\n      startTime: '09:00',\n      endTime: '10:00',\n      label: '新时段',\n      color: defaultColors[data.value.slots.length % defaultColors.length]\n    }\n\n    const newSlots = [...data.value.slots, newSlot]\n    data.value.slots = sortSlotsByTime(newSlots)\n    lastError.value = null\n    return true\n  }\n\n  const updateSlot = (id: string, updates: Partial<TimeSlot>): boolean => {\n    const index = data.value.slots.findIndex(s => s.id === id)\n    if (index === -1) return false\n\n    const currentSlot = data.value.slots[index]\n    const updatedSlot = { ...currentSlot, ...updates }\n\n    const startTime = updates.startTime ?? currentSlot.startTime\n    const endTime = updates.endTime ?? currentSlot.endTime\n\n    const newSlots = [...data.value.slots]\n    newSlots[index] = updatedSlot\n    data.value.slots = sortSlotsByTime(newSlots)\n\n    if (timeToMinutes(startTime) >= timeToMinutes(endTime)) {\n      lastError.value = '结束时间必须晚于开始时间'\n    } else {\n      lastError.value = null\n    }\n\n    return true\n  }\n\n  const deleteSlot = (id: string) => {\n    data.value.slots = data.value.slots.filter(s => s.id !== id)\n  }\n\n  const resetToDefault = () => {\n    data.value = {\n      title: '我的作息时间表',\n      slots: sortSlotsByTime([...defaultSlots])\n    }\n    lastError.value = null\n  }\n\n  const clearError = () => {\n    lastError.value = null\n  }\n\n  return {\n    data,\n    addSlot,\n    updateSlot,\n    deleteSlot,\n    resetToDefault,\n    defaultColors,\n    lastError,\n    clearError\n  }\n}\n","<script setup lang=\"ts\">\nimport html2canvas from 'html2canvas'\nimport type { TimeSlot } from '~/types'\n\nconst { data, addSlot, updateSlot, deleteSlot, resetToDefault, defaultColors, lastError, clearError } = useTimetable()\n\nconst activeTab = ref<'edit' | 'preview'>('edit')\nconst previewRef = ref<InstanceType<typeof TimetablePreview> | null>(null)\nconst showAddModal = ref(false)\n\nconst exportImage = async () => {\n  if (!previewRef.value?.timetableRef) return\n\n  try {\n    const canvas = await html2canvas(previewRef.value.timetableRef, {\n      scale: 2,\n      useCORS: true,\n      backgroundColor: '#ffffff'\n    })\n\n    const link = document.createElement('a')\n    link.download = `${data.value.title || '作息时间表'}.png`\n    link.href = canvas.toDataURL('image/png')\n    link.click()\n  } catch (error) {\n    console.error('导出失败:', error)\n  }\n}\n\nconst handleUpdateSlot = (id: string, updates: Partial<TimeSlot>) => {\n  updateSlot(id, updates)\n}\n\nconst handleDeleteSlot = (id: string) => {\n  deleteSlot(id)\n}\n\nconst handleAddSlot = () => {\n  showAddModal.value = true\n}\n\nconst handleModalConfirm = (slotData: Omit<TimeSlot, 'id'>) => {\n  addSlot(slotData)\n  showAddModal.value = false\n}\n\nconst handleModalClose = () => {\n  showAddModal.value = false\n}\n</script>\n\n<template>\n  <div class=\"min-h-screen bg-gradient-to-br from-blue-50 via-white to-purple-50\">\n    <header class=\"bg-white shadow-sm border-b border-gray-100\">\n      <div class=\"max-w-6xl mx-auto px-4 py-4\">\n        <div class=\"flex items-center justify-between\">\n          <div>\n            <h1 class=\"text-2xl font-bold text-gray-800\">作息时间表编辑器</h1>\n            <p class=\"text-sm text-gray-500 mt-1\">创建你的专属作息计划</p>\n          </div>\n          <div class=\"flex items-center gap-3\">\n            <button\n              @click=\"resetToDefault\"\n              class=\"px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg transition-colors text-sm\"\n            >\n              重置默认\n            </button>\n            <button\n              v-if=\"activeTab === 'preview'\"\n              @click=\"exportImage\"\n              class=\"px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium flex items-center gap-2\"\n            >\n              <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4\" />\n              </svg>\n              导出图片\n            </button>\n          </div>\n        </div>\n\n        <div class=\"flex gap-2 mt-4\">\n          <button\n            @click=\"activeTab = 'edit'\"\n            class=\"px-4 py-2 rounded-lg text-sm font-medium transition-colors\"\n            :class=\"activeTab === 'edit' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'\"\n          >\n            编辑模式\n          </button>\n          <button\n            @click=\"activeTab = 'preview'\"\n            class=\"px-4 py-2 rounded-lg text-sm font-medium transition-colors\"\n            :class=\"activeTab === 'preview' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'\"\n          >\n            预览模式\n          </button>\n        </div>\n      </div>\n    </header>\n\n    <main class=\"max-w-6xl mx-auto px-4 py-8\">\n      <div v-if=\"activeTab === 'edit'\">\n        <div class=\"mb-6\">\n          <label class=\"text-sm font-medium text-gray-700 mb-2 block\">时间表标题</label>\n          <input\n            v-model=\"data.title\"\n            type=\"text\"\n            placeholder=\"输入时间表标题\"\n            class=\"w-full max-w-md px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg\"\n          />\n        </div>\n\n        <div class=\"mb-4 flex items-center justify-between\">\n          <h2 class=\"text-lg font-semibold text-gray-700\">时段列表</h2>\n          <span class=\"text-sm text-gray-500\">{{ data.slots.length }} 个时段</span>\n        </div>\n\n        <div\n          v-if=\"lastError\"\n          class=\"mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-red-600 text-sm flex items-center gap-2\"\n        >\n          <svg class=\"w-5 h-5 flex-shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n          </svg>\n          {{ lastError }}\n        </div>\n\n        <div class=\"space-y-2\">\n          <TimeSlotEditor\n            v-for=\"slot in data.slots\"\n            :key=\"slot.id\"\n            :slot=\"slot\"\n            :colors=\"defaultColors\"\n            @update=\"handleUpdateSlot\"\n            @delete=\"handleDeleteSlot\"\n          />\n        </div>\n\n        <button\n          @click=\"handleAddSlot\"\n          class=\"mt-4 w-full py-4 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 hover:border-blue-400 hover:text-blue-600 hover:bg-blue-50 transition-colors flex items-center justify-center gap-2\"\n        >\n          <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 4v16m8-8H4\" />\n          </svg>\n          添加新时段\n        </button>\n      </div>\n\n      <div v-else>\n        <TimetablePreview ref=\"previewRef\" :data=\"data\" />\n      </div>\n    </main>\n\n    <AddSlotModal\n      :show=\"showAddModal\"\n      :colors=\"defaultColors\"\n      @close=\"handleModalClose\"\n      @confirm=\"handleModalConfirm\"\n    />\n  </div>\n</template>\n"],"version":3}